{
  "name": "mimocode-desktop",
  "private": true,
  "version": "0.1.1",
  "description": "Aria Chat — an AI assistant with Claude-desktop-style Electron UI for the Aria local server",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "pack": "pwsh -File script/pack-portable.ps1",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "ansi-to-html": "^0.7.2",
    "emoji-regex": "^10.6.0",
    "highlight.js": "^11.11.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  }
}
